APP_ENV=development
HTTP_PORT=8080
METRICS_PORT=9090

# Database Connections
DATABASE_URL=postgres://nexus:nexus_secret@localhost:5432/nexuslink?sslmode=disable
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://nexus:nexus_secret@localhost:5672/nexuslink

# Rates & Bounds
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
HASH_LENGTH=7
LOG_LEVEL=debug

# Analytics Workers
BATCH_SIZE=500
BATCH_TIMEOUT=5s
WORKER_CONCURRENCY=4
